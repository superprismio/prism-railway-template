{
  "name": "@prism-railway/codex-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "configure:provider": "bash scripts/configure-custom-provider.sh",
    "dev": "tsx watch src/index.ts",
