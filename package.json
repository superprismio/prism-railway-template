{
  "name": "prism-agent-railway",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:local": "bash scripts/dev-local-stack.sh",
    "local:init": "node scripts/prism-local.mjs init",
    "local:up": "node scripts/prism-local.mjs up",
    "local:down": "node scripts/prism-local.mjs down",
    "local:status": "node scripts/prism-local.mjs status",
    "local:doctor": "node scripts/prism-local.mjs doctor",
    "local:logs": "node scripts/prism-local.mjs logs",
    "local:open": "node scripts/prism-local.mjs open",
    "lint": "npm run lint --workspaces --if-present",
    "railway:deploy-prism-stack": "bash scripts/railway-deploy-prism-stack.sh",
    "railway:bootstrap-site": "bash scripts/railway-bootstrap-api.sh",
    "railway:bootstrap-api": "bash scripts/railway-bootstrap-api.sh",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
