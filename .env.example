# Shared
NODE_ENV=development
SESSION_SECRET=replace-me
INTERNAL_SERVICE_TOKEN=replace-me

# Site
PORT=3100
SITE_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3100
API_INTERNAL_BASE_URL=http://127.0.0.1:3100
SITE_USE_LOCAL_APP_API=true
PRISM_AGENT_DATA_ROOT=./services/site/data
ADMIN_EMAIL=admin@local.agent
ADMIN_PASSWORD=changeme
PRISM_MEMORY_BASE_URL=http://127.0.0.1:8788
PRISM_API_READ_KEY=replace-me

# Codex runtime
CODEX_RUNTIME_PORT=3030
CODEX_RUNTIME_BASE_URL=http://127.0.0.1:3030
CODEX_HOME=$HOME/.codex
CODEX_RUNTIME_TIMEOUT_MS=600000
CODEX_WORKSPACE_ROOT=.
CODEX_TARGET_WORKSPACE_ROOT=./.codex-target-workspaces
APP_API_BASE_URL=http://127.0.0.1:3100
APP_API_SERVICE_TOKEN=replace-me
PRISM_API_BASE=http://127.0.0.1:8788
PRISM_API_KEY=replace-me
TARGET_REPO_GITHUB_TOKEN=
GIT_AUTHOR_NAME="Prism Codex"
GIT_AUTHOR_EMAIL=prism-codex@users.noreply.github.com

# Prism memory
PRISM_API_PORT=8788
PRISM_API_BASE_PATH=/prism-memory
PRISM_API_DATA_ROOT=./services/prism-memory/data
PRISM_API_SPACE=community
# Optional agentic inbox enrichment (disabled by default)
AGENTIC_INGEST_MODE=off
AGENTIC_INGEST_SCOPE=bot_only
# Optional override for space.json provider.base_url
AGENTIC_INGEST_PROVIDER_BASE_URL=
# Optional override for space.json provider API key
AGENTIC_INGEST_PROVIDER_API_KEY=
# Optional override for space.json provider.model
AGENTIC_INGEST_MODEL=
AGENTIC_INGEST_TIMEOUT_SECONDS=30
AGENTIC_INGEST_SCOPED_SOURCES=
AGENTIC_INGEST_SCOPED_BUCKETS=

# Discord source adapter
SOURCE_ADAPTER_PORT=8789
SOURCE_KIND=discord
SOURCE_SPACE=community
SOURCE_SYNC_MODE=manual
SOURCE_ADAPTER_TOKEN=replace-me
SOURCE_ADAPTER_DATA_ROOT=./services/source-adapter/data
PRISM_INGEST_PATH=/ingest/messages
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_COMMAND_GUILD_ID=
DISCORD_REGISTER_COMMANDS=true
DISCORD_CHAT_ENABLED=true
DISCORD_SYNC_WINDOW_HOURS=24
DISCORD_MAX_MESSAGES_PER_CHANNEL=200
DISCORD_INCLUDE_ARCHIVED_THREADS=false
DISCORD_IGNORE_BOT_MESSAGES=false
DISCORD_ATTACHMENT_TEXT_ENABLED=true
DISCORD_EMBED_TEXT_ENABLED=true

# Discord voice transcription and summaries
VOICE_TRANSCRIPTION_BASE_URL=https://api.venice.ai/api/v1/audio/transcriptions
VOICE_TRANSCRIPTION_API_KEY=
VOICE_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3
VOICE_TRANSCRIPTION_LANGUAGE=en
VOICE_TRANSCRIPTION_RESPONSE_FORMAT=json
VOICE_TRANSCRIPTION_TIMESTAMPS=true
VOICE_DAVE_ENCRYPTION=true
VOICE_CHAT_IGNORE_BOT_MESSAGES=true
CODEX_RUNTIME_REQUEST_TIMEOUT_SECONDS=660

# Generic cron trigger services
PRISM_TRIGGER_PATH=/ops/memory/run
PRISM_TRIGGER_AUTH_HEADER=X-Prism-Api-Key
PRISM_TRIGGER_AUTH_TOKEN=replace-me
PRISM_TRIGGER_BODY={}
